// use external mediamtx tool for Dwarf streams
NEXT_PUBLIC_PORT_PROXY_CORS=8860
// Update NEXT_PUBLIC_PORT_PROXY_CORS Value in server/server.ts with the same value
NEXT_PUBLIC_PORT_PROXY_CORS_HTTPS=9443
// Update NEXT_PUBLIC_PORT_PROXY_CORS_HTTPS Value in server/server.ts with the same value

NEXT_PUBLIC_IP_MEDIAMTX=localhost
NEXT_PUBLIC_URL_PROXY_CORS=/api/proxy

// ssl certificates
// create them with npm run certificate:Platform
NODE_EXTRA_CA_CERTS=/cert/DwarfiumCert.pem